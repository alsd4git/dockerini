# Monitoring Stack Environment Variables

# Required
DOCKER_DATA_BASEFOLDER=/opt/docker/data
DOCKER_MEDIA_BASEFOLDER=/opt/docker/media
PUBLIC_DOMAIN=example.com

# ==================== Beszel Server Configuration ====================
# SSH public key for Beszel agent authentication
BESZEL_SSH_KEY=ssh-ed25519 ---
# Authentication token for Beszel agent
BESZEL_TOKEN=
# Beszel hub URL
BESZEL_HUB_URL=https://beszel.example.org

# ==================== Pi-hole Widget Configuration ====================
# Password used by Homepage to read Pi-hole statistics
PIHOLE_PASSWORD=REPLACE_ME

# ==================== Homepage Service Widget Keys ====================
# Portainer widget API key
PORTAINER_API_KEY=REPLACE_ME
# Jellyfin widget API key
JELLYFIN_API_KEY=REPLACE_ME
# Seerr widget API key
SEERR_API_KEY=REPLACE_ME
# Prowlarr widget API key
PROWLARR_API_KEY=REPLACE_ME
# Radarr widget API key
RADARR_API_KEY=REPLACE_ME
# Sonarr widget API key
SONARR_API_KEY=REPLACE_ME
# qBittorrent widget credentials
QBITTORRENT_USERNAME=REPLACE_ME
QBITTORRENT_PASSWORD=REPLACE_ME
# Immich widget API key
IMMICH_API_KEY=REPLACE_ME
# Speedtest Tracker widget API token
SPEEDTEST_TRACKER_API_TOKEN=REPLACE_ME

# ==================== Homarr Configuration ====================
# Optional: Secret encryption key for Homarr dashboard
# Generate with: openssl rand -hex 32
HOMARR_SECRET_ENCRYPTION_KEY=somethings

# ==================== Speedtest Tracker Configuration ====================
# Optional: App key for Speedtest Tracker
# Generate with: openssl rand -base64 32
SPEEDTEST_TRACKER_APP_KEY=base64:------
