# Nginx Proxy Manager Stack Environment Variables

# Required
DOCKER_DATA_BASEFOLDER=/opt/docker/data
YOUR_DOMAIN=example.com

# Optional: TinyAuth v4 + Pocket ID integration
# TinyAuth is an authentication middleware for protecting services
# Pocket ID is an OIDC provider for passkey-based authentication
# Make sure Pocket ID has OAuth application configured with callback:
#   https://tinyauth.{YOUR_DOMAIN}/api/oauth/callback/pocketid
POCKET_ID_CLIENT_ID=
POCKET_ID_CLIENT_SECRET=

# Optional: Step CA configuration (for mTLS)
STEP_CA_NAME=My Certificate Authority
STEP_CA_DNS_NAMES=ca.example.com,ca.local
STEP_CA_PASSWORD=your_ca_password

# Optional: VaultLS configuration
VAULTLS_API_SECRET=
VAULTLS_URL=https://vault.example.com