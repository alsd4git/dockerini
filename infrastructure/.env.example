# Infrastructure Stack Environment Variables (Nginx Proxy Manager, DDNS, Pocket ID, Authentication)

# Required
DOCKER_DATA_BASEFOLDER=/opt/docker/data
YOUR_DOMAIN=example.com

# ==================== DDNS Updater Configuration ====================
# Required for Telegram notifications
TELEGRAM_CHAT_ID=REPLACE_ME
TELEGRAM_BOT_TOKEN=REPLACE_ME

# Optional: DDNS Provider credentials (uncomment and fill as needed)
# Dynu DNS provider
DYNU_DOMAIN=yourdomain.freeddns.org
DYNU_USERNAME=your_dyn_username
DYNU_PASSWORD=your_dyn_password

# Dynv6 DNS provider
DYN6_DOMAIN=yourdomain.dynv6.net
DYN6_TOKEN=your_dynv6_token

# DuckDNS provider
DUCK_HOST=yourdomain.duckdns.org
DUCK_TOKEN=your_duckdns_token

# Cloudflare DNS provider
CLOUDFLARE_DOMAIN=yourdomain.com
CLOUDFLARE_TOKEN=your_cloudflare_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# ==================== Pocket ID Configuration ====================
# See: https://pocket-id.org/docs/configuration/environment-variables
# Generate SESSION_DURATION in minutes (default: 600)
# MAXMIND_LICENSE_KEY for geolocation features (optional)
# ENCRYPTION_KEY is required for Pocket ID v2 (generate with: openssl rand -base64 32)
APP_URL=pocket-id.example.org #should be set to your Pocket ID url
ENCRYPTION_KEY=REPLACE_ME
SESSION_DURATION=600
MAXMIND_LICENSE_KEY=
TRUST_PROXY=true

# ==================== TinyAuth v5 + Pocket ID Integration ====================
# TinyAuth v5 uses TINYAUTH_ prefixed configuration options.
# Pocket ID is an OIDC provider for passkey-based authentication.
# Make sure Pocket ID has an OAuth application configured with callback:
#   https://tinyauth.{YOUR_DOMAIN}/api/oauth/callback/pocketid
TINYAUTH_OAUTH_PROVIDERS_POCKETID_CLIENTID=
TINYAUTH_OAUTH_PROVIDERS_POCKETID_CLIENTSECRET=

# ==================== Step CA Configuration (for mTLS) ====================
STEP_CA_NAME=My Certificate Authority
STEP_CA_DNS_NAMES=ca.example.com,ca.local
STEP_CA_PASSWORD=your_ca_password

# ==================== VaultLS Configuration ====================
VAULTLS_API_SECRET=
VAULTLS_URL=https://vault.example.com
