# Forgejo Stack
# Rootless Forgejo with a Postgres backend, exposed through Nginx Proxy Manager.
#
# Required environment variables:
# - DOCKER_DATA_BASEFOLDER: Base directory for persistent data
# - YOUR_DOMAIN: your domain name (e.g. your-domain.duckdns.org)
# - FORGEJO_DB_PASSWORD: Database password shared by Forgejo and Postgres
#
# Optional environment variables:
# - FORGEJO_VERSION: Forgejo image tag (default: 13-rootless)
# - POSTGRES_VERSION: Postgres image tag (default: 17-alpine)
# - FORGEJO_DB_NAME: Database name (default: forgejo)
# - FORGEJO_DB_USER: Database user (default: forgejo)
# - FORGEJO_DISABLE_REGISTRATION: Disable self-service registration (default: true)
# - FORGEJO_REQUIRE_SIGNIN_VIEW: Require sign-in to view pages (default: true)
# - FORGEJO_SSH_PORT: SSH clone port shown in Forgejo and published by Docker (default: 2222)
# - FORGEJO_ALLOWED_USER_VISIBILITY_MODES: User visibility modes allowed by the instance (default: private)
# - FORGEJO_DEFAULT_USER_VISIBILITY: Default visibility for new user profiles (default: private)
# - FORGEJO_DEFAULT_ORG_VISIBILITY: Default visibility for new organizations (default: private)
# - FORGEJO_FORCE_PRIVATE: Force every new repository to be private (default: true)
# - FORGEJO_DEFAULT_PRIVATE: Default privacy mode for new repositories (default: private)
# - FORGEJO_DEFAULT_PUSH_CREATE_PRIVATE: Default privacy for push-to-create repositories (default: true)
# - FORGEJO_ENABLE_PUSH_CREATE_USER: Allow push-to-create for user repositories (default: true)
# - FORGEJO_ENABLE_PUSH_CREATE_ORG: Allow push-to-create for organization repositories (default: true)
# - FORGEJO_DISABLE_REGULAR_ORG_CREATION: Disable organization creation by non-admin users (default: true)

YOUR_DOMAIN=your-domain.duckdns.org

FORGEJO_VERSION=13-rootless
POSTGRES_VERSION=17-alpine
FORGEJO_DB_NAME=forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=REPLACE_ME

FORGEJO_DISABLE_REGISTRATION=true
FORGEJO_REQUIRE_SIGNIN_VIEW=true
FORGEJO_SSH_PORT=2222
FORGEJO_ALLOWED_USER_VISIBILITY_MODES=private
FORGEJO_DEFAULT_USER_VISIBILITY=private
FORGEJO_DEFAULT_ORG_VISIBILITY=private
FORGEJO_FORCE_PRIVATE=true
FORGEJO_DEFAULT_PRIVATE=private
FORGEJO_DEFAULT_PUSH_CREATE_PRIVATE=true
FORGEJO_ENABLE_PUSH_CREATE_USER=true
FORGEJO_ENABLE_PUSH_CREATE_ORG=true
FORGEJO_DISABLE_REGULAR_ORG_CREATION=true
